---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HIKES DIGITAL – SAP-Architektur & Entwicklung" description="Ihr Partner für SAP-Architektur, Fiori/UI5, ABAP und S/4HANA – mit Klarheit und Weitblick.">

  <!-- ── NAVIGATION ── -->
  <header id="site-header" class="fixed top-0 left-0 right-0 z-50 flex justify-between items-center px-8 md:px-14 py-5 transition-all duration-500">
    <a href="/" id="nav-logo" class="opacity-0 transition-all duration-500 pointer-events-none">
      <img
        src="/images/logo/Logo_Hikes-Digital_Wort-Bildmarke_quer_rot-weiss.png"
        alt="HIKES DIGITAL"
        class="h-12 w-auto"
      />
    </a>
    <nav class="hidden md:flex gap-10">
      <a href="#leistungen" class="text-base font-bold tracking-widest uppercase text-white/85 hover:text-white transition-colors">Leistungen</a>
      <a href="#philosophie" class="text-base font-bold tracking-widest uppercase text-white/85 hover:text-white transition-colors">Philosophie</a>
      <a href="#projekte" class="text-base font-bold tracking-widest uppercase text-white/85 hover:text-white transition-colors">Projekte</a>
      <a href="#ueber-uns" class="text-base font-bold tracking-widest uppercase text-white/85 hover:text-white transition-colors">Über uns</a>
      <a href="#kontakt" class="text-base font-bold tracking-widest uppercase text-[#E94B53] hover:text-white transition-colors">Kontakt</a>
    </nav>
  </header>

  <!-- ── HERO ── -->
  <section class="relative flex items-end overflow-hidden h-screen">

    <!-- Background image -->
    <img
      id="hero-img"
      src="/images/hikes_digital_header.jpeg"
      alt="Berglandschaft"
      class="absolute inset-0 w-full h-full object-cover will-change-transform"
    />

    <!-- Dark overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0F1828] via-[#0F1828]/40 to-[#0F1828]/20"></div>

    <!-- Logo signet watermark top-left -->
    <div class="absolute top-20 left-6 w-56 md:w-72 pointer-events-none z-10 signet-animate">
      <img
        src="/images/logo/Logo_Hikes-Digital_Bildmarke_rot.png"
        alt=""
        class="w-full h-full object-contain brightness-0 invert"
      />
    </div>

    <!-- Text content bottom-left -->
    <div class="relative z-10 px-6 md:px-14 pb-12 md:pb-16 max-w-5xl">
      <h1 data-reveal data-delay="100" class="text-5xl sm:text-7xl md:text-9xl font-bold text-white leading-none uppercase [hyphens:none]">
        HIKES DIGITAL
      </h1>
      <p data-reveal data-delay="200" class="mt-3 md:mt-4 text-xs sm:text-sm md:text-xl lg:text-2xl font-light text-white/80 max-w-xs sm:max-w-lg md:max-w-2xl">
        SAP-Architektur & Entwicklung mit Klarheit und Weitblick
      </p>
      <div data-reveal data-delay="300" class="mt-6 md:mt-8 flex flex-col sm:flex-row gap-3 md:gap-4">
        <a href="#leistungen" class="px-6 md:px-8 py-3 md:py-4 bg-[#E94B53] text-white text-sm md:text-base font-bold tracking-widest uppercase hover:bg-white hover:text-[#0F1828] transition-colors text-center">
          Leistungen
        </a>
        <a href="#kontakt" class="px-6 md:px-8 py-3 md:py-4 border border-white/30 text-white text-sm md:text-base font-bold tracking-widest uppercase hover:border-white transition-colors text-center">
          Kontakt
        </a>
      </div>
    </div>

    <!-- Arrow bottom-right — hidden on mobile to avoid overlap -->
    <div class="hidden sm:block absolute bottom-8 right-10 z-10">
      <a href="#intro" aria-label="Nach unten scrollen">
        <img src="/images/objects/arrow-down.svg" alt="" class="w-20 h-20 opacity-90 hover:opacity-100 transition-opacity" />
      </a>
    </div>
  </section>

  <!-- ── INTRO ── -->
  <section id="intro" class="bg-[#0F1828] text-white py-28 px-8 md:px-14">
    <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-start">
      <h2 data-reveal="left" class="text-3xl md:text-4xl lg:text-5xl font-bold leading-tight">
        Spezialisiert auf SAP,<br/>fokussiert auf<br/>Ihren Erfolg.
      </h2>
      <div data-reveal="right">
        <p class="text-lg md:text-xl lg:text-2xl font-light text-white/80 leading-relaxed">
          Wie erfahrene Pfadfinder navigieren wir durch das SAP-Gelände: mit tiefem Know-how in ABAP, SAP Fiori und S/4HANA. Wir begleiten Unternehmen sicher durch Systemwechsel, Individualentwicklungen und digitale Herausforderungen – Schritt für Schritt, zielgerichtet und mit klarem Kompass.
        </p>
        <div class="mt-8 w-14 h-0.5 bg-[#E94B53]"></div>
      </div>
    </div>
  </section>

  <!-- ── LEISTUNGEN ── -->
  <section id="leistungen" class="bg-[#0B1220] text-white py-28 px-8 md:px-14">
    <div class="max-w-6xl mx-auto">
      <p class="text-base font-bold tracking-[0.3em] uppercase text-[#E94B53] mb-5">Was wir tun</p>
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-bold mb-12 md:mb-20 max-w-xl">Leistungen, die den Weg ebnen.</h2>

      <div class="divide-y divide-white/10 border-y border-white/10">

        <!-- Row 1 -->
        <div class="leistung-item" data-reveal data-delay="100">
          <button class="leistung-toggle group w-full text-left flex items-center gap-5 md:gap-16 py-8 md:py-10 cursor-pointer">
            <div class="leistung-icon hidden md:block shrink-0 text-white/40 group-hover:text-[#E94B53] transition-colors duration-300">
              <svg width="48" height="48" viewBox="0 0 32 32" fill="none">
                <rect x="11" y="2" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="2.5"/>
                <rect x="2" y="22" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="2.5"/>
                <rect x="20" y="22" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="2.5"/>
                <path d="M16 9V15M16 15H7M16 15H25M7 15V22M25 15V22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="leistung-bar hidden md:block shrink-0 w-0.5 h-14 bg-white/10 group-hover:bg-[#E94B53] transition-colors duration-300"></div>
            <div class="flex-1 min-w-0">
              <h3 class="text-xl md:text-2xl lg:text-3xl font-bold uppercase tracking-wide text-white group-hover:text-[#E94B53] transition-colors duration-300 mb-2">Architektur & Konzeption</h3>
              <p class="text-lg font-light text-white/75 leading-relaxed">SAP-Lösungen ganzheitlich gedacht – von Anfang an mit klarem Fokus auf nachhaltige, skalierbare technische Konzepte.</p>
            </div>
            <svg class="leistung-chevron shrink-0 w-7 h-7 text-white/30 group-hover:text-[#E94B53] transition-all duration-300" viewBox="0 0 24 24" fill="none">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="leistung-body overflow-hidden max-h-0 transition-[max-height] duration-500 ease-in-out">
            <div class="flex gap-5 md:gap-16 pb-8 md:pb-10">
              <div class="hidden md:block shrink-0 w-12"></div>
              <div class="leistung-bar-ext hidden md:block shrink-0 w-0.5 bg-white/10"></div>
              <div class="flex-1 space-y-4 text-base md:text-lg font-light text-white/80 leading-relaxed">
                <p>Wir denken SAP-Lösungen von Anfang an ganzheitlich – mit einem klaren Fokus auf nachhaltige technische Konzepte. Als Sparringspartner unterstützen wir Projektteams und Entscheider dabei, tragfähige Architekturen zu entwickeln, saubere Erweiterungspunkte zu identifizieren und moderne Technologien sinnvoll einzusetzen.</p>
                <p>Unser Anspruch: Lösungen, die nicht nur heute funktionieren, sondern auch morgen noch weitergedacht werden können.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Row 2 -->
        <div class="leistung-item" data-reveal data-delay="200">
          <button class="leistung-toggle group w-full text-left flex items-center gap-5 md:gap-16 py-8 md:py-10 cursor-pointer">
            <div class="leistung-icon hidden md:block shrink-0 text-white/40 group-hover:text-[#E94B53] transition-colors duration-300">
              <svg width="48" height="48" viewBox="0 0 32 32" fill="none"><rect x="3" y="5" width="26" height="18" rx="2" stroke="currentColor" stroke-width="2.5"/><path d="M10 27H22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M16 23V27" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            </div>
            <div class="leistung-bar hidden md:block shrink-0 w-0.5 h-14 bg-white/10 group-hover:bg-[#E94B53] transition-colors duration-300"></div>
            <div class="flex-1 min-w-0">
              <h3 class="text-xl md:text-2xl lg:text-3xl font-bold uppercase tracking-wide text-white group-hover:text-[#E94B53] transition-colors duration-300 mb-2">Fiori & UI5</h3>
              <p class="text-lg font-light text-white/75 leading-relaxed">Nutzerzentrierte, moderne Oberflächen, die SAP-Standards sinnvoll erweitern – technisch solide und wartbar.</p>
            </div>
            <svg class="leistung-chevron shrink-0 w-7 h-7 text-white/30 group-hover:text-[#E94B53] transition-all duration-300" viewBox="0 0 24 24" fill="none">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="leistung-body overflow-hidden max-h-0 transition-[max-height] duration-500 ease-in-out">
            <div class="flex gap-5 md:gap-16 pb-8 md:pb-10">
              <div class="hidden md:block shrink-0 w-12"></div>
              <div class="leistung-bar-ext hidden md:block shrink-0 w-0.5 bg-white/10"></div>
              <div class="flex-1 space-y-4 text-base md:text-lg font-light text-white/80 leading-relaxed">
                <p>Moderne Oberflächen sind mehr als nur schick – sie machen Prozesse verständlicher, schneller und angenehmer. Wir entwickeln passgenaue Fiori- und UI5-Anwendungen, die den SAP-Standard gezielt erweitern.</p>
                <p>Dabei achten wir nicht nur auf Design, sondern auch auf technische Qualität, Wiederverwendbarkeit und einfache Wartung.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Row 3 -->
        <div class="leistung-item" data-reveal data-delay="300">
          <button class="leistung-toggle group w-full text-left flex items-center gap-5 md:gap-16 py-8 md:py-10 cursor-pointer">
            <div class="leistung-icon hidden md:block shrink-0 text-white/40 group-hover:text-[#E94B53] transition-colors duration-300">
              <svg width="48" height="48" viewBox="0 0 32 32" fill="none"><path d="M8 10L4 16L8 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M24 10L28 16L24 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 6L13 26" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>
            </div>
            <div class="leistung-bar hidden md:block shrink-0 w-0.5 h-14 bg-white/10 group-hover:bg-[#E94B53] transition-colors duration-300"></div>
            <div class="flex-1 min-w-0">
              <h3 class="text-xl md:text-2xl lg:text-3xl font-bold uppercase tracking-wide text-white group-hover:text-[#E94B53] transition-colors duration-300 mb-2">ABAP Entwicklung</h3>
              <p class="text-lg font-light text-white/75 leading-relaxed">Sauberer Code mit modernen Ansätzen – Clean ABAP, RAP und CDS mit dem Blick für das große Ganze.</p>
            </div>
            <svg class="leistung-chevron shrink-0 w-7 h-7 text-white/30 group-hover:text-[#E94B53] transition-all duration-300" viewBox="0 0 24 24" fill="none">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="leistung-body overflow-hidden max-h-0 transition-[max-height] duration-500 ease-in-out">
            <div class="flex gap-5 md:gap-16 pb-8 md:pb-10">
              <div class="hidden md:block shrink-0 w-12"></div>
              <div class="leistung-bar-ext hidden md:block shrink-0 w-0.5 bg-white/10"></div>
              <div class="flex-1 space-y-4 text-base md:text-lg font-light text-white/80 leading-relaxed">
                <p>Sauberer Code ist kein Zufall. Wir entwickeln maßgeschneiderte ABAP-Lösungen, die nicht nur funktionieren, sondern auch strukturiert, erweiterbar und zukunftssicher sind.</p>
                <p>Dabei bringen wir moderne Entwicklungsansätze wie Clean ABAP, RAP oder CDS gezielt zum Einsatz – immer mit Blick auf die Gesamtarchitektur.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Row 4 -->
        <div class="leistung-item" data-reveal data-delay="400">
          <button class="leistung-toggle group w-full text-left flex items-center gap-5 md:gap-16 py-8 md:py-10 cursor-pointer">
            <div class="leistung-icon hidden md:block shrink-0 text-white/40 group-hover:text-[#E94B53] transition-colors duration-300">
              <svg width="48" height="48" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="2.5"/><path d="M16 8V16L21 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="leistung-bar hidden md:block shrink-0 w-0.5 h-14 bg-white/10 group-hover:bg-[#E94B53] transition-colors duration-300"></div>
            <div class="flex-1 min-w-0">
              <h3 class="text-xl md:text-2xl lg:text-3xl font-bold uppercase tracking-wide text-white group-hover:text-[#E94B53] transition-colors duration-300 mb-2">S/4HANA Readiness</h3>
              <p class="text-lg font-light text-white/75 leading-relaxed">Gezielte Analysen, Machbarkeitsbewertungen und objektive Code-Reviews für Migrationen und Optimierungen.</p>
            </div>
            <svg class="leistung-chevron shrink-0 w-7 h-7 text-white/30 group-hover:text-[#E94B53] transition-all duration-300" viewBox="0 0 24 24" fill="none">
              <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="leistung-body overflow-hidden max-h-0 transition-[max-height] duration-500 ease-in-out">
            <div class="flex gap-5 md:gap-16 pb-8 md:pb-10">
              <div class="hidden md:block shrink-0 w-12"></div>
              <div class="leistung-bar-ext hidden md:block shrink-0 w-0.5 bg-white/10"></div>
              <div class="flex-1 space-y-4 text-base md:text-lg font-light text-white/80 leading-relaxed">
                <p>Ein Umstieg auf S/4HANA erfordert mehr als nur einen technischen Upgrade. Wir unterstützen mit gezielten Analysen, Machbarkeitsbewertungen und objektiven Code Reviews – damit alte Zöpfe abgeschnitten und moderne Standards genutzt werden können.</p>
                <p>Auch als Vorbereitung für Brownfield-Projekte oder gezielte Optimierungen im laufenden Betrieb.</p>
              </div>
            </div>
          </div>
        </div>

      </div>

    </div>
  </section>

  <!-- ── PHILOSOPHIE / WARUM ── -->
  <section id="philosophie" class="relative h-[50vh] flex items-end overflow-hidden">
    <img
      src="/images/hikes_it-beratung.png"
      alt="Berglandschaft mit Wanderer"
      class="absolute inset-0 w-full h-full object-cover object-center"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#0F1828] via-[#0F1828]/20 to-transparent"></div>
    <div class="relative z-10 px-8 md:px-14 pb-10">
      <h2 class="text-4xl md:text-6xl lg:text-8xl xl:text-9xl font-bold text-white uppercase leading-none tracking-tight">
        Warum HIKES DIGITAL?
      </h2>
    </div>
  </section>

  <!-- WARUM content – condensed -->
  <section class="bg-[#0F1828] text-white py-16 px-8 md:px-14">
    <div class="max-w-6xl mx-auto">

      <!-- Intro + pullquote side by side -->
      <div class="grid md:grid-cols-2 gap-12 mb-12 pb-12 border-b border-white/10">
        <div data-reveal="left">
          <p class="text-xl font-light text-white/80 leading-relaxed mb-4">
            HIKES DIGITAL ist eine SAP-Technologieberatung mit klarem Fokus:
            <strong class="font-bold text-white"> nachhaltige Lösungen statt kurzfristiger Workarounds.</strong>
          </p>
          <p class="text-lg font-light text-white/75 leading-relaxed">
            Wir unterstützen Unternehmen dabei, ihre SAP-Systeme zukunftssicher, effizient und nutzerfreundlich zu gestalten – mit moderner Entwicklung, sauberer Architektur und einem echten Verständnis für die Prozesse dahinter.
          </p>
        </div>
        <div data-reveal="right">
          <p class="text-base font-bold tracking-[0.3em] uppercase text-[#E94B53] mb-4">Was uns auszeichnet</p>
          <p class="text-lg font-light text-white/80 leading-relaxed mb-3">
            Für unsere Kunden sind wir ein verlässlicher Partner in komplexen SAP-Vorhaben – lösungsorientiert, partnerschaftlich und mit Weitblick.
          </p>
          <p class="text-lg font-light text-white/80 leading-relaxed">
            Stabile, erweiterbare SAP-Komponenten, die sich im Alltag bewähren – mit modernen Technologien und bewährten Standards.
          </p>
        </div>
      </div>

      <!-- Wer dahintersteht + speech bubble quote -->
      <div class="grid md:grid-cols-2 gap-12 items-start">
        <div data-reveal="left">
          <p class="text-base font-bold tracking-[0.3em] uppercase text-[#E94B53] mb-4">Wer dahintersteht</p>
          <p class="text-lg font-light text-white/80 leading-relaxed mb-3">
            Gegründet wurde HIKES DIGITAL von Maik Pfäffle – SAP-Entwickler und Architekt mit langjähriger Erfahrung in ABAP, Fiori und S/4HANA-Projekten.
          </p>
          <p class="text-lg font-light text-white/80 leading-relaxed">
            Was ihn antreibt: der Wunsch, ein Unternehmen aufzubauen, das nicht nur Strategien entwirft, sondern moderne SAP-Lösungen realisiert – mit Fokus auf technische Konzeption, zukunftsfähige Architektur und eine Umsetzung, die im Alltag der Kunden spürbar wird.
          </p>
        </div>

        <div data-reveal="right">
          <!-- Speech bubble -->
          <div class="relative">
            <div class="bg-[#E94B53] p-8 rounded-2xl">
              <p class="text-white font-light italic leading-relaxed text-lg">
                „Ich freue mich, wenn unsere Arbeit im Alltag der Kunden spürbar ist – wenn HIKES DIGITAL für Lösungen steht, auf die man sich verlassen kann, die nicht nur funktionieren, sondern auch im Unternehmen wirken."
              </p>
            </div>
            <!-- Tail pointing bottom-left, flush with rounded corner -->
            <div class="w-5 h-5 bg-[#E94B53]" style="clip-path: polygon(0 0, 100% 0, 0 100%); margin-left: 2.5rem;"></div>
          </div>
          <div class="flex items-center gap-4 mt-4">
            <img
              src="/images/employees/maik/DSC09725%20Klein.png"
              alt="Maik Pfäffle"
              class="w-14 h-14 rounded-full object-cover object-top"
            />
            <div>
              <p class="font-bold text-white text-base">Maik Pfäffle</p>
              <p class="font-light text-white/65 text-base">Geschäftsführer & IT-Berater</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ── PROJEKTE ── -->
  <section id="projekte" class="bg-[#131f33] text-white py-28 px-8 md:px-14">
    <div class="max-w-6xl mx-auto">
      <p class="text-base font-bold tracking-[0.3em] uppercase text-[#E94B53] mb-5">Referenzen</p>
      <h2 class="text-3xl md:text-5xl lg:text-6xl font-bold mb-12 md:mb-20 max-w-xl">Projekte, die Spuren hinterlassen.</h2>

      <div class="grid md:grid-cols-2 gap-px bg-white/5">

        <!-- Tile 1 — tall -->
        <button data-modal="projekt1" data-reveal data-delay="100"
          class="group relative bg-[#0F1828] overflow-hidden text-left p-7 md:p-12 min-h-[16rem] md:min-h-[22rem] flex flex-col justify-end cursor-pointer">
          <!-- big background number -->
          <span class="absolute top-4 right-6 text-[9rem] font-bold leading-none text-white/[0.04] select-none pointer-events-none transition-colors duration-500 group-hover:text-white/[0.08]">01</span>
          <!-- red hover fill -->
          <div class="absolute inset-0 bg-[#E94B53] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <p class="text-sm font-bold tracking-[0.25em] uppercase text-[#E94B53] group-hover:text-white mb-4 transition-colors duration-300">BRF+ · RAP · Fiori</p>
            <h3 class="text-lg md:text-2xl lg:text-3xl font-bold text-white leading-snug mb-4 md:mb-6">
              Intelligente Verteilung von Materialstammdaten
            </h3>
            <span class="inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase text-white/80 group-hover:text-white transition-colors duration-300">
              Details ansehen
              <svg class="w-4 h-4 translate-x-0 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </button>

        <!-- Tile 2 — short + offset feel via padding -->
        <button data-modal="projekt2" data-reveal data-delay="200"
          class="group relative bg-[#131f33] overflow-hidden text-left p-7 md:p-12 min-h-[16rem] md:min-h-[22rem] flex flex-col justify-end cursor-pointer">
          <span class="absolute top-4 right-6 text-[9rem] font-bold leading-none text-white/[0.04] select-none pointer-events-none transition-colors duration-500 group-hover:text-white/[0.08]">02</span>
          <div class="absolute inset-0 bg-[#E94B53] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative z-10">
            <p class="text-sm font-bold tracking-[0.25em] uppercase text-[#E94B53] group-hover:text-white mb-4 transition-colors duration-300">OData · IDoc · Integration</p>
            <h3 class="text-lg md:text-2xl lg:text-3xl font-bold text-white leading-snug mb-4 md:mb-6">
              SAP-Integration einer Non-SAP Cloud-Lösung im Einkauf
            </h3>
            <span class="inline-flex items-center gap-2 text-sm font-bold tracking-widest uppercase text-white/80 group-hover:text-white transition-colors duration-300">
              Details ansehen
              <svg class="w-4 h-4 translate-x-0 group-hover:translate-x-1 transition-transform duration-300" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
          </div>
        </button>

        <!-- Tile 3 -->
        <button data-modal="projekt3" data-reveal data-delay="300"
