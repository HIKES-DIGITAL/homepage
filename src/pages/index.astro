  <!-- ── MODAL OVERLAY ── -->
  <div id="modal-overlay" class="fixed inset-0 z-[200] flex items-center justify-center p-3 md:p-6 opacity-0 pointer-events-none transition-opacity duration-300">
    <div class="absolute inset-0 bg-[#0F1828]/90 backdrop-blur-sm" id="modal-backdrop"></div>
    <div id="modal-box" class="relative bg-[#131f33] border border-white/10 max-w-2xl w-full max-h-[90vh] overflow-y-auto overflow-x-hidden translate-y-8 transition-transform duration-300 shadow-2xl">
      <!-- Red top bar -->
      <div class="h-1 bg-[#E94B53] w-full"></div>
      <!-- Close button -->
      <button id="modal-close" class="absolute top-4 right-4 text-white/75 hover:text-white transition-colors text-xl leading-none font-light w-8 h-8 flex items-center justify-center">✕</button>
      <div class="p-5 md:p-14">
        <div id="modal-icon" class="text-[#E94B53] mb-3 md:mb-6 hidden md:block"></div>
        <p id="modal-tags" class="text-xs font-bold tracking-[0.2em] uppercase text-[#E94B53] mb-2 md:mb-4 hidden"></p>
        <h3 id="modal-title" class="text-xl md:text-4xl font-bold uppercase tracking-normal md:tracking-wide text-white mb-4 md:mb-8 leading-snug break-words pr-8"></h3>
        <div id="modal-body" class="text-sm md:text-lg font-light text-white/85 leading-relaxed space-y-4"></div>
      </div>
    </div>
  </div>

  <script>
    // ── Scroll reveal ──
    const revealEls = document.querySelectorAll('[data-reveal]');
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    revealEls.forEach((el) => revealObserver.observe(el));

    // Trigger hero elements immediately (already in view on load)
    document.querySelectorAll('[data-reveal]').forEach((el) => {
      if (el.getBoundingClientRect().top < window.innerHeight) {
        setTimeout(() => el.classList.add('is-visible'),
          parseInt(el.dataset.delay || '0'));
      }
    });

    // ── Header transparency on scroll ──
    const header = document.getElementById('site-header');
    const updateHeader = () => {
      if (window.scrollY > 60) {
        header.classList.add('bg-[#0F1828]/90', 'backdrop-blur-md');
        header.classList.remove('bg-transparent');
      } else {
        header.classList.remove('bg-[#0F1828]/90', 'backdrop-blur-md');
        header.classList.add('bg-transparent');
      }
    };
    updateHeader();
    window.addEventListener('scroll', updateHeader, { passive: true });

    // ── Nav logo show/hide based on hero ──
    const navLogo = document.getElementById('nav-logo');
    const heroSection = document.querySelector('section');
    const logoObserver = new IntersectionObserver(([entry]) => {
      const past = !entry.isIntersecting;
      navLogo.classList.toggle('opacity-0', !past);
      navLogo.classList.toggle('pointer-events-none', !past);
    }, { threshold: 0.1 });
    if (heroSection) logoObserver.observe(heroSection);

    // ── Hero parallax ──
    const heroImg = document.getElementById('hero-img');
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      if (heroImg && scrollY < window.innerHeight) {
        heroImg.style.transform = `translateY(${scrollY * 0.35}px)`;
      }
    }, { passive: true });

    // ── Active nav highlight ──
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('nav a[href^="#"]');

    const navObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const active = link.getAttribute('href') === `#${entry.target.id}`;
            link.classList.toggle('!text-[#E94B53]', active);
          });
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px' });

    sections.forEach((section) => navObserver.observe(section));

    // ── Modal overlay ──
    const modalData = {
      architektur: {
        icon: `<svg width="44" height="44" viewBox="0 0 32 32" fill="none"><rect x="11" y="2" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="2.5"/><rect x="2" y="22" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="2.5"/><rect x="20" y="22" width="10" height="7" rx="1.5" stroke="currentColor" stroke-width="2.5"/><path d="M16 9V15M16 15H7M16 15H25M7 15V22M25 15V22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>`,
        title: 'Architektur & Konzeption',
        body: `<p>Wir denken SAP-Lösungen von Anfang an ganzheitlich – mit einem klaren Fokus auf nachhaltige technische Konzepte. Als Sparringspartner unterstützen wir Projektteams und Entscheider dabei, tragfähige Architekturen zu entwickeln, saubere Erweiterungspunkte zu identifizieren und moderne Technologien sinnvoll einzusetzen.</p><p>Unser Anspruch: Lösungen, die nicht nur heute funktionieren, sondern auch morgen noch weitergedacht werden können.</p>`
      },
      fiori: {
        icon: `<svg width="44" height="44" viewBox="0 0 32 32" fill="none"><rect x="3" y="5" width="26" height="18" rx="2" stroke="currentColor" stroke-width="2.5"/><path d="M10 27H22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M16 23V27" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>`,
        title: 'Fiori & UI5',
        body: `<p>Moderne Oberflächen sind mehr als nur schick – sie machen Prozesse verständlicher, schneller und angenehmer. Wir entwickeln passgenaue Fiori- und UI5-Anwendungen, die den SAP-Standard gezielt erweitern.</p><p>Dabei achten wir nicht nur auf Design, sondern auch auf technische Qualität, Wiederverwendbarkeit und einfache Wartung.</p>`
      },
      abap: {
        icon: `<svg width="44" height="44" viewBox="0 0 32 32" fill="none"><path d="M8 10L4 16L8 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M24 10L28 16L24 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M19 6L13 26" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg>`,
        title: 'ABAP Entwicklung',
        body: `<p>Sauberer Code ist kein Zufall. Wir entwickeln maßgeschneiderte ABAP-Lösungen, die nicht nur funktionieren, sondern auch strukturiert, erweiterbar und zukunftssicher sind.</p><p>Dabei bringen wir moderne Entwicklungsansätze wie Clean ABAP, RAP oder CDS gezielt zum Einsatz – immer mit Blick auf die Gesamtarchitektur.</p>`
      },
      s4hana: {
        icon: `<svg width="44" height="44" viewBox="0 0 32 32" fill="none"><circle cx="16" cy="16" r="12" stroke="currentColor" stroke-width="2.5"/><path d="M16 8V16L21 19" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
        title: 'S/4HANA Readiness',
        body: `<p>Ein Umstieg auf S/4HANA erfordert mehr als nur einen technischen Upgrade. Wir unterstützen mit gezielten Analysen, Machbarkeitsbewertungen und objektiven Code Reviews – damit alte Zöpfe abgeschnitten und moderne Standards genutzt werden können.</p><p>Auch als Vorbereitung für Brownfield-Projekte oder gezielte Optimierungen im laufenden Betrieb.</p>`
      }
    };

    const overlay = document.getElementById('modal-overlay');
    const modalBox = document.getElementById('modal-box');
    const modalIcon = document.getElementById('modal-icon');
    const modalTitle = document.getElementById('modal-title');
    const modalTags = document.getElementById('modal-tags');
    const modalBody = document.getElementById('modal-body');
    const modalClose = document.getElementById('modal-close');
    const modalBackdrop = document.getElementById('modal-backdrop');

    function openModal(key) {
      const data = modalData[key];
      if (!data) return;
      modalIcon.innerHTML = data.icon;
      if (data.tags) {
        modalTags.textContent = data.tags;
        modalTags.classList.remove('hidden');
      } else {
        modalTags.classList.add('hidden');
      }
      modalTitle.textContent = data.title;
      modalBody.innerHTML = data.body;
      overlay.classList.remove('opacity-0', 'pointer-events-none');
      requestAnimationFrame(() => modalBox.classList.remove('translate-y-8'));
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modalBox.classList.add('translate-y-8');
      overlay.classList.add('opacity-0', 'pointer-events-none');
      document.body.style.overflow = '';
    }

    // Projekt tiles still use modal
    document.querySelectorAll('[data-modal]').forEach((btn) => {
      btn.addEventListener('click', () => openModal(btn.dataset.modal));
    });

    // ── Leistungen accordion ──
    document.querySelectorAll('.leistung-item').forEach((item) => {
      const toggle  = item.querySelector('.leistung-toggle');
      const body    = item.querySelector('.leistung-body');
      const chevron = item.querySelector('.leistung-chevron');
      const bar     = item.querySelector('.leistung-bar');
      const icon    = item.querySelector('.leistung-icon');

      toggle.addEventListener('click', () => {
        const isOpen = body.style.maxHeight && body.style.maxHeight !== '0px';

        // Close all
        document.querySelectorAll('.leistung-item').forEach((el) => {
          el.querySelector('.leistung-body').style.maxHeight = '0px';
          el.querySelector('.leistung-chevron').style.transform = '';
          el.querySelector('.leistung-bar').classList.replace('bg-[#E94B53]', 'bg-white/10');
          el.querySelector('.leistung-bar-ext').classList.replace('bg-[#E94B53]', 'bg-white/10');
          el.querySelector('.leistung-icon').classList.replace('text-[#E94B53]', 'text-white/40');
        });

        // Open clicked
        if (!isOpen) {
          body.style.maxHeight = body.scrollHeight + 'px';
          chevron.style.transform = 'rotate(180deg)';
          bar.classList.replace('bg-white/10', 'bg-[#E94B53]');
          item.querySelector('.leistung-bar-ext').classList.replace('bg-white/10', 'bg-[#E94B53]');
          icon.classList.replace('text-white/40', 'text-[#E94B53]');
        }
      });
    });

    modalClose.addEventListener('click', closeModal);
    modalBackdrop.addEventListener('click', closeModal);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // ── Projekte modal data ──
    const projektData = {
      projekt1: {
        icon: `<span class="text-5xl font-bold text-[#E94B53]/30 leading-none">01</span>`,
        title: 'Intelligente Verteilung von Materialstammdaten mit BRF+ und Fiori',
        tags: 'BRF+ · RAP · Fiori',
        body: `<p>Für einen weltweit führenden Hersteller wurde ein verteilter Materialstammprozess auf Basis von RAP und BRF+ entwickelt. Die Lösung erlaubt eine feldweise Steuerung der Verteilung, läuft asynchron und bietet durch Fiori Apps volle Transparenz und manuelle Eingriffsmöglichkeiten.</p>`
      },
      projekt2: {
        icon: `<span class="text-5xl font-bold text-[#E94B53]/30 leading-none">02</span>`,
        title: 'SAP-Integration einer Non-SAP Cloud-Lösung im Einkauf',
        tags: 'OData · IDoc · Integration',
        body: `<p>Bei einem Kunden aus der Rüstungsindustrie wurde eine Lieferanten-Cloudlösung in den SAP-Einkaufsprozess integriert. Per OData und IDoc wurden Bestell- und Stammdaten bidirektional angebunden – SAP blieb das führende System, während Lieferanten in der Cloud arbeiten.</p>`
      },
      projekt3: {
        icon: `<span class="text-5xl font-bold text-[#E94B53]/30 leading-none">03</span>`,
        title: 'SAPUI5-Wizard zur Digitalisierung des Erstmusterprozesses',
        tags: 'SAPUI5 · QM · Digitalisierung',
        body: `<p>Für ein produzierendes Unternehmen wurde eine SAPUI5 App entwickelt, die den Erstmusterprozess digitalisiert. Der Prozess ermöglicht es Qualitätsmitarbeitern, Daten effizient zu erfassen, Dokumente hochzuladen und automatisch eine QM-Meldung zu erstellen. Über eine flexible Steuerung wird der Prozess je nach Ergebnis entweder abgeschlossen oder wiederholt.</p>`
      },
      projekt4: {
        icon: `<span class="text-5xl font-bold text-[#E94B53]/30 leading-none">04</span>`,
        title: 'S/4HANA-Migration: Zukunftssichere Transformation des kundeneigenen ABAP-Codes',
        tags: 'S/4HANA · ABAP · Migration',
        body: `<p>Im Rahmen einer ERP-zu-S/4HANA-Transformation wurde der gesamte Eigenentwicklungsbestand eines Produktionsunternehmens analysiert, bereinigt und in SCRUM-Arbeitspakete überführt. Nicht kompatible Altlösungen wurden durch moderne Ersatzprozesse ersetzt – für eine saubere und zukunftsfähige Codebasis.</p>`
      }
    };

    Object.assign(modalData, projektData);

    // ── Contact form ──
    const contactForm = document.getElementById('contact-form');
    const contactSubmit = document.getElementById('contact-submit');
    const formSuccess = document.getElementById('form-success');
    const formError = document.getElementById('form-error');

    contactForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      contactSubmit.disabled = true;
      contactSubmit.textContent = 'Wird gesendet …';
      formError.classList.add('hidden');

      try {
        const res = await fetch(contactForm.action, {
          method: 'POST',
          body: new FormData(contactForm),
          headers: { Accept: 'application/json' }
        });

        if (res.ok) {
          contactForm.querySelectorAll('input, textarea, button').forEach(el => el.classList.add('hidden'));
          formSuccess.classList.remove('hidden');
        } else {
          throw new Error('server error');
        }
      } catch {
        contactSubmit.disabled = false;
        contactSubmit.textContent = 'Nachricht senden';
        formError.classList.remove('hidden');
      }
    });
